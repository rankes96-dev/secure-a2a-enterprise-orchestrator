{
  "name": "real-external-agent",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:jira": "tsx watch src/startConnector.ts jira",
    "dev:servicenow": "tsx watch src/startConnector.ts servicenow",
    "dev:github": "tsx watch src/startConnector.ts github",
    "start": "node dist/index.js",
    "start:jira": "node dist/startConnector.js jira",
    "start:servicenow": "node dist/startConnector.js servicenow",
    "start:github": "node dist/startConnector.js github",
    "clean": "node ../scripts/clean-dist.mjs",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "verify:agent": "tsx src/verify-agent.ts"
  },
  "dependencies": {
    "jose": "^5.10.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5"
  }
}
