NODE_ENV=production
HOST=0.0.0.0
PORT=<railway-provided-port>
EXTERNAL_AGENT_ADMIN_ENABLED=false
EXTERNAL_AGENT_ADMIN_TOKEN=<long-random-admin-token-if-enabled>

# Set these per Railway connector service.
EXTERNAL_CONNECTOR_ID=jira-reference
EXTERNAL_AGENT_ID=external-jira-agent
EXTERNAL_AGENT_CLIENT_ID=jira-agent-client

# ServiceNow values:
# EXTERNAL_CONNECTOR_ID=servicenow-reference
# EXTERNAL_AGENT_ID=external-servicenow-agent
# EXTERNAL_AGENT_CLIENT_ID=servicenow-agent-client

# GitHub values:
# EXTERNAL_CONNECTOR_ID=github-reference
# EXTERNAL_AGENT_ID=external-github-agent
# EXTERNAL_AGENT_CLIENT_ID=github-agent-client

AGENT_ISSUER=https://<connector-agent>.railway.app
MOCK_IDP_ISSUER=https://<mock-idp>.railway.app
MOCK_IDP_JWKS_URI=https://<mock-idp>.railway.app/.well-known/jwks.json
EXPECTED_AUDIENCE=<external-agent-id>
TRUSTED_GATEWAY_ISSUER=https://<orchestrator>.railway.app
TRUSTED_GATEWAY_CLIENT_ID=secure-a2a-gateway-client
TRUSTED_GATEWAY_JWKS_URI=https://<orchestrator>.railway.app/.well-known/jwks.json
