# Railway production orchestrator template.
NODE_ENV=production
HOST=0.0.0.0
PORT=4000
ALLOWED_ORIGINS=https://<vercel-app>.vercel.app

# OpenRouter is the production AI provider.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Shared state/session/replay store. Production uses Upstash Redis.
STATE_STORE_DRIVER=upstash
STATE_STORE_KEY_PREFIX=a2a
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

ORCHESTRATOR_API_KEY=generate_a_long_random_client_api_key
INTERNAL_SERVICE_TOKEN=generate_a_long_random_internal_service_token
MAX_BODY_BYTES=65536
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30
SESSION_RATE_LIMIT_WINDOW_MS=60000
SESSION_RATE_LIMIT_MAX_REQUESTS=20
AGENT_ONBOARDING_RATE_LIMIT_WINDOW_MS=60000
AGENT_ONBOARDING_RATE_LIMIT_MAX_REQUESTS=20
HEALTH_RATE_LIMIT_WINDOW_MS=60000
HEALTH_RATE_LIMIT_MAX_REQUESTS=30
TRUST_PROXY_HEADERS=false
SHOW_INTERNAL_HEALTH_URLS=false
SESSION_TTL_MS=3600000
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=None

# Secure A2A Identity settings.
A2A_IDP_URL=https://<mock-idp>.railway.app
A2A_JWKS_URI=https://<mock-idp>.railway.app/.well-known/jwks.json
A2A_AUTH_MODE=oauth2_client_credentials_jwt
REQUIRE_SECURE_A2A_AUTH=true
ORCHESTRATOR_CLIENT_ID=servicenow-orchestrator-agent
ORCHESTRATOR_CLIENT_SECRET=

# private_key_jwt is required for the production demo.
ORCHESTRATOR_TOKEN_AUTH_METHOD=private_key_jwt
ORCHESTRATOR_PRIVATE_KEY_JWT_ENABLED=true
ORCHESTRATOR_PRIVATE_KEY_JWT_AUDIENCE=https://<mock-idp>.railway.app/oauth/token
ORCHESTRATOR_PRIVATE_JWK_JSON=
ORCHESTRATOR_ALLOWED_AUTH_METHODS=private_key_jwt

# Local specialist agent task endpoints. In production connector-first runtime uses onboarded external connector URLs.
JIRA_AGENT_URL=http://localhost:4101/task
GITHUB_AGENT_URL=http://localhost:4102/task
PAGERDUTY_AGENT_URL=http://localhost:4103/task
SECURITY_OAUTH_AGENT_URL=http://localhost:4104/task
API_HEALTH_AGENT_URL=http://localhost:4105/task
END_USER_TRIAGE_AGENT_URL=http://localhost:4106/task

# Mock IdP token endpoint source IP allowlist.
MOCK_IDP_ENFORCE_IP_ALLOWLIST=false
MOCK_IDP_ALLOWED_SOURCE_IPS=
MOCK_IDP_ALLOWED_SOURCE_CIDRS=
