AI_PROVIDER=openrouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-4o-mini

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini

ORCHESTRATOR_API_KEY=generate_a_long_random_client_api_key
INTERNAL_SERVICE_TOKEN=generate_a_long_random_internal_service_token
ALLOWED_ORIGINS=https://your-frontend-domain.example
HOST=0.0.0.0
PORT=4000
MAX_BODY_BYTES=65536
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30
SESSION_TTL_MS=3600000
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=None

# Secure A2A Identity settings. Use mock_internal_token for simple local mode or oauth2_client_credentials_jwt for full JWT mode.
A2A_IDP_URL=http://localhost:4110
A2A_JWKS_URI=http://localhost:4110/.well-known/jwks.json
A2A_AUTH_MODE=mock_internal_token
ORCHESTRATOR_CLIENT_ID=servicenow-orchestrator-agent
ORCHESTRATOR_CLIENT_SECRET=dev-secret

# Token client authentication. client_secret_post is the simple local fallback.
ORCHESTRATOR_TOKEN_AUTH_METHOD=client_secret_post

# private_key_jwt is the preferred Secure A2A client authentication mode.
ORCHESTRATOR_PRIVATE_KEY_JWT_ENABLED=false
ORCHESTRATOR_PRIVATE_KEY_JWT_AUDIENCE=http://localhost:4110/oauth/token
ORCHESTRATOR_PRIVATE_JWK_JSON=
ORCHESTRATOR_PUBLIC_JWK_JSON=
ORCHESTRATOR_ALLOWED_AUTH_METHODS=private_key_jwt,client_secret_post

# Agent task endpoints. Use Railway private/internal URLs in deployed backend-to-backend mode when available.
JIRA_AGENT_URL=http://localhost:4101/task
GITHUB_AGENT_URL=http://localhost:4102/task
PAGERDUTY_AGENT_URL=http://localhost:4103/task
SECURITY_OAUTH_AGENT_URL=http://localhost:4104/task
API_HEALTH_AGENT_URL=http://localhost:4105/task
END_USER_TRIAGE_AGENT_URL=http://localhost:4106/task

# Mock IdP token endpoint source IP allowlist.
MOCK_IDP_ENFORCE_IP_ALLOWLIST=false
MOCK_IDP_ALLOWED_SOURCE_IPS=127.0.0.1,::1,::ffff:127.0.0.1
MOCK_IDP_ALLOWED_SOURCE_CIDRS=
TRUST_PROXY_HEADERS=false

# Shared state store for security/runtime state. Use upstash only when UPSTASH_REDIS_REST_URL/TOKEN are configured.
STATE_STORE_DRIVER=memory
STATE_STORE_KEY_PREFIX=a2a
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
