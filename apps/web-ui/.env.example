VITE_ORCHESTRATOR_API_URL=http://localhost:4000
VITE_AUTH_PROVIDER=mock
VITE_JIRA_AGENT_URL=http://localhost:4201
VITE_SERVICENOW_AGENT_URL=http://localhost:4202
VITE_GITHUB_AGENT_URL=http://localhost:4203

# Future Auth0 browser login settings. These are public SPA values only.
# Configure Auth0 SPA callbacks to use /auth/callback, not the app root.
# VITE_AUTH_PROVIDER=auth0
# VITE_AUTH0_DOMAIN=<tenant>.auth0.com
# VITE_AUTH0_CLIENT_ID=<spa-client-id>
# VITE_AUTH0_AUDIENCE=<api-audience>

# For Vercel, set this to the Railway orchestrator URL:
# VITE_ORCHESTRATOR_API_URL=https://<orchestrator-api>.up.railway.app
# VITE_JIRA_AGENT_URL=https://jira-external-agent-production.up.railway.app
# VITE_SERVICENOW_AGENT_URL=https://servicenow-external-agent-production.up.railway.app
# VITE_GITHUB_AGENT_URL=https://github-external-agent-production.up.railway.app
