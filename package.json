{
  "name": "secure-a2a-enterprise-integration-resolver",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n web,orchestrator,triage,jira,github,pagerduty,oauth,health,idp -c blue,green,white,magenta,cyan,yellow,red,white,gray \"npm run dev -w apps/web-ui\" \"set PORT=4000&& npm run dev -w services/orchestrator-api\" \"set PORT=4106&& npm run dev -w services/end-user-triage-agent\" \"set PORT=4101&& npm run dev -w services/jira-agent\" \"set PORT=4102&& npm run dev -w services/github-agent\" \"set PORT=4103&& npm run dev -w services/pagerduty-agent\" \"set PORT=4104&& npm run dev -w services/security-oauth-agent\" \"set PORT=4105&& npm run dev -w services/api-health-agent\" \"set PORT=4110&& npm run dev -w services/mock-identity-provider\"",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "verify:a2a-token": "tsx scripts/verify-a2a-token.ts",
    "verify:mock-idp-ip-allowlist": "tsx scripts/verify-mock-idp-ip-allowlist.ts",
    "verify:private-key-jwt-replay": "tsx scripts/verify-private-key-jwt-replay.ts",
    "verify:agent-onboarding": "tsx scripts/verify-agent-onboarding.ts",
    "verify:connector-routing": "tsx scripts/verify-connector-routing.ts",
    "verify:multi-connector-routing": "tsx scripts/verify-multi-connector-routing.ts",
    "verify:external-connector-instance": "tsx scripts/verify-external-connector-instance.ts",
    "verify:scale-cleanliness": "tsx scripts/verify-scale-cleanliness.ts",
    "verify:ui-copy": "tsx scripts/verify-ui-copy.ts",
    "verify:ui-style": "tsx scripts/verify-ui-style.ts",
    "verify:runtime-safety": "tsx scripts/verify-runtime-safety.ts",
    "verify:decision-engine": "tsx scripts/verify-decision-engine.ts",
    "verify:policy-model": "tsx scripts/verify-policy-model.ts",
    "verify:audit-events": "tsx scripts/verify-audit-events.ts",
    "verify:ai-config": "tsx scripts/verify-ai-config.ts",
    "verify:user-identity": "tsx scripts/verify-user-identity.ts",
    "verify:user-identity-required": "tsx scripts/verify-user-identity-required.ts",
    "verify:trust-status": "tsx scripts/verify-trust-status.ts",
    "verify:security-timeline": "tsx scripts/verify-security-timeline.ts",
    "generate:orchestrator-client-key": "tsx scripts/generate-orchestrator-client-key.ts"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.11"
  },
  "dependencies": {
    "jose": "^5.10.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
