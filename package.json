{
  "name": "secure-a2a-enterprise-integration-resolver",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*",
    "real-external-agent"
  ],
  "scripts": {
    "dev": "node scripts/dev-services.mjs",
    "build": "npm run build:shared && npm run build:apps && npm run build:backends",
    "build:shared": "npm run build -w @a2a/shared",
    "build:apps": "npm run build -w apps/web-ui",
    "build:backends": "npm run build -w services/orchestrator-api && npm run build -w services/mock-identity-provider && npm run build -w services/end-user-triage-agent && npm run build -w services/jira-agent && npm run build -w services/github-agent && npm run build -w services/pagerduty-agent && npm run build -w services/security-oauth-agent && npm run build -w services/api-health-agent && npm run build -w real-external-agent",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "verify:v1": "npm run typecheck && npm run build && npm run verify:production-build && npm run verify:end-user-product && npm run verify:ui-copy && npm run verify:ui-components && npm run verify:ui-style && npm run verify:persona-mode && npm run verify:chat-keyboard && npm run verify:connector-test-center && npm run verify:runtime-safety && npm run verify:deployment-readiness && npm run verify:demo-readiness && npm run verify:identity-provider && npm run verify:pr8-review-fixes",
    "verify:v2-plan": "tsx scripts/verify-v2-plan.ts",
    "verify:v1:e2e": "npm run verify:connector-routing && npm run verify:multi-connector-routing",
    "verify:a2a-token": "tsx scripts/verify-a2a-token.ts",
    "verify:mock-idp-ip-allowlist": "tsx scripts/verify-mock-idp-ip-allowlist.ts",
    "verify:private-key-jwt-replay": "tsx scripts/verify-private-key-jwt-replay.ts",
    "verify:agent-onboarding": "tsx scripts/verify-agent-onboarding.ts",
    "verify:connector-routing": "tsx scripts/verify-connector-routing.ts",
    "verify:multi-connector-routing": "tsx scripts/verify-multi-connector-routing.ts",
    "verify:external-connector-instance": "tsx scripts/verify-external-connector-instance.ts",
    "verify:scale-cleanliness": "tsx scripts/verify-scale-cleanliness.ts",
    "verify:ui-copy": "tsx scripts/verify-ui-copy.ts",
    "verify:ui-components": "tsx scripts/verify-ui-components.ts",
    "verify:ui-style": "tsx scripts/verify-ui-style.ts",
    "verify:persona-mode": "tsx scripts/verify-persona-mode.ts",
    "verify:chat-keyboard": "tsx scripts/verify-chat-keyboard.ts",
    "verify:deployment-readiness": "tsx scripts/verify-deployment-readiness.ts",
    "verify:end-user-product": "tsx scripts/verify-end-user-product.ts",
    "verify:production-build": "tsx scripts/verify-production-build.ts",
    "verify:demo-readiness": "tsx scripts/verify-demo-readiness.ts",
    "verify:diagnostic-runtime-semantics": "tsx scripts/verify-diagnostic-runtime-semantics.ts",
    "verify:execution-gate-stack": "tsx scripts/verify-execution-gate-stack.ts",
    "verify:connector-test-center": "tsx scripts/verify-connector-test-center.ts",
    "verify:connector-action-planning": "tsx scripts/verify-connector-action-planning.ts",
    "verify:planning-follow-up": "tsx scripts/verify-planning-follow-up.ts",
    "verify:safe-target-selection": "tsx scripts/verify-safe-target-selection.ts",
    "verify:pending-interaction-resolver": "tsx scripts/verify-pending-interaction-resolver.ts",
    "verify:runtime-safety": "tsx scripts/verify-runtime-safety.ts",
    "verify:decision-engine": "tsx scripts/verify-decision-engine.ts",
    "verify:policy-model": "tsx scripts/verify-policy-model.ts",
    "verify:audit-events": "tsx scripts/verify-audit-events.ts",
    "verify:ai-config": "tsx scripts/verify-ai-config.ts",
    "verify:user-identity": "tsx scripts/verify-user-identity.ts",
    "verify:identity-provider": "tsx scripts/verify-identity-provider-abstraction.ts",
    "verify:user-identity-required": "tsx scripts/verify-user-identity-required.ts",
    "verify:trust-status": "tsx scripts/verify-trust-status.ts",
    "verify:security-timeline": "tsx scripts/verify-security-timeline.ts",
    "verify:pr8-review-fixes": "tsx scripts/verify-pr8-review-fixes.ts",
    "generate:orchestrator-client-key": "tsx scripts/generate-orchestrator-client-key.ts"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.11"
  },
  "dependencies": {
    "jose": "^5.10.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
