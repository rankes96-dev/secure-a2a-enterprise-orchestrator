{
  "name": "@a2a/shared",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./http": {
      "types": "./src/http.ts",
      "default": "./dist/http.js"
    }
  },
  "scripts": {
    "clean": "node ../../scripts/clean-dist.mjs",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "jose": "^5.10.0"
  }
}
